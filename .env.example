# ─────────────────────────────────────────────────────────────
# Chronogest 2.1-V — Variables de entorno requeridas
# Copiar como .env y completar TODOS los valores marcados como REQUERIDO
# ─────────────────────────────────────────────────────────────

# ── Base de datos principal (epsas_db) ──────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=           # REQUERIDO — sin valor por defecto en código
DB_NAME=epsas_db

# ── Base de datos de horarios (horarios_db) ──────────────────
HORARIOS_DB_HOST=localhost
HORARIOS_DB_PORT=5432
HORARIOS_DB_NAME=horarios_db
# Reutiliza DB_PASSWORD si no se define HORARIOS_DB_PASSWORD

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=            # REQUERIDO — mínimo 32 caracteres aleatorios

# ── Redis (BullMQ) ───────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Entorno ──────────────────────────────────────────────────
NODE_ENV=production    # development | production

# ── Servidor ─────────────────────────────────────────────────
PORT=3000
