# ─────────────────────────────────────────────────────────────────────────────
# ChronoGest — Variables de entorno del backend (desarrollo local sin Docker)
# Copiar este archivo como .env y completar los valores
# ─────────────────────────────────────────────────────────────────────────────

# Entorno — cambiar a "production" para deshabilitar synchronize automático
NODE_ENV=development

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=3000

# ── Base de datos principal (epsas_db) ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5435
DB_USERNAME=postgres
DB_PASSWORD=chronogest2024
DB_NAME=epsas_db

# ── Base de datos de horarios (horarios_db) ───────────────────────────────────
HORARIOS_DB_HOST=localhost
HORARIOS_DB_PORT=5435
HORARIOS_DB_NAME=horarios_db

# ── Base de datos maestra de tenants (Centros de Formación) ───────────────────
MASTER_DB_HOST=localhost
MASTER_DB_PORT=5435
MASTER_DB_USER=postgres
MASTER_DB_PASSWORD=postgres
MASTER_DB_NAME=chronogest_master_db

# ── Redis (cola BullMQ) ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=chronogest_sena_jwt_secret_2024_very_secure_key_abc123
ROOT_JWT_SECRET=chronogest_root_jwt_secret_cambia_esto_en_produccion

# ── Root user (administra MASTER_DB, ver scripts/seed-root-user.ts) ───────────
ROOT_SEED_EMAIL=
ROOT_SEED_PASSWORD=

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4200
